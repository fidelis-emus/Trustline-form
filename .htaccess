# TrustLine Capital / Aegis Private Banking - Apache & cPanel Configuration
# Domain: kyctrustlinecapital.com

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # Enable CORS headers
    Header always set Access-Control-Allow-Origin "*"
    Header always set Access-Control-Allow-Methods "GET, POST, PUT, DELETE, OPTIONS"
    Header always set Access-Control-Allow-Headers "Content-Type, Authorization, X-Requested-With, X-API-Key"

    # Handle OPTIONS preflight requests
    RewriteCond %{REQUEST_METHOD} OPTIONS
    RewriteRule ^(.*)$ $1 [R=200,L]

    # Protect SQLite database from public download
    RewriteRule ^storage/database\.sqlite$ - [F,L]
    RewriteRule ^storage/.*\.log$ - [F,L]

    # Route API requests to api.php
    RewriteRule ^api/(.*)$ api.php/$1 [QSA,L]
    RewriteRule ^api$ api.php [QSA,L]

    # SPA Fallback routing for React Frontend
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^ index.html [L]
</IfModule>

# Options
Options -Indexes
